{
  "name": "nyx-game-editor-root",
  "private": true,
  "version": "0.1.0",
  "description": "nyx.js — a standalone 2D game engine and editor built with Electron, Svelte, and PixiJS.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minititan-studio/nyx.js.git"
  },
  "scripts": {
    "dev": "pnpm --filter @nyx/editor dev",
    "dist": "pnpm --filter @nyx/editor dist",
    "dist:win": "pnpm --filter @nyx/editor dist:win",
    "build": "pnpm --filter @nyx/editor build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  }
}
