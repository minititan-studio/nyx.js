{
    "include": ["src/**/*"],
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": false,
        "strictNullChecks": true,
        "strictPropertyInitialization": false,
        "noImplicitAny": false,
        "exactOptionalPropertyTypes": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": false,
        "ignoreDeprecations": "5.0",
        "baseUrl": "src",
        "paths": {
            "camera":                    ["./camera.ts"],
            "index":                     ["./index.ts"],
            "rooms":                     ["./rooms.ts"],
            "sounds":                    ["./sounds.ts"],
            "styles":                    ["./styles.ts"],
            "res":                       ["./res.ts"],
            "u":                         ["./u.ts"],
            "fittoscreen":               ["./fittoscreen.ts"],
            "@nyx/shared":               ["../../../packages/shared/src/index.ts"],
            "@pixi/sound":               ["../../../node_modules/@pixi/sound/lib/index.d.ts"],
            "@pixi/sound/lib":           ["../../../node_modules/@pixi/sound/lib/index.d.ts"],
            "@pixi/particle-emitter":    ["../../../node_modules/@pixi/particle-emitter/dist/types/index.d.ts"]
        },
        "typeRoots": [
            "../../../node_modules/@types"
        ]
    }
}
