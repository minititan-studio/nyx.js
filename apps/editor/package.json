{
  "name": "@nyx/editor",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/minititan-studio/nyx.js.git",
    "directory": "apps/editor"
  },
  "author": {
    "name": "minititan",
    "email": "head@minititan.online"
  },
  "description": "Nyx Studio is a game editor built with web technologies, designed to be cross-platform and user-friendly.",
  "type": "module",
  "main": "out/electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src electron",
    "dist": "electron-vite build && electron-builder",
    "dist:win": "electron-vite build && node -e \"try{require('fs').rmSync('dist',{recursive:true,force:true})}catch(e){}\" && electron-builder --win",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "build": {
    "appId": "dev.nyxgame.editor",
    "productName": "Nyx Studio",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.modules.yaml",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "../runtime/dist",
        "to": "runtime/dist"
      },
      {
        "from": "../runtime/src/nyx.css",
        "to": "runtime/src/nyx.css"
      },
      {
        "from": "../runtime/src/types",
        "to": "runtime/src/types"
      },
      {
        "from": "resources/nyx.libs",
        "to": "nyx.libs"
      },
      {
        "from": "../../packages/engine/src",
        "to": "engine/src"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@iconify-json/feather": "^1.2.1",
    "@iconify-json/material-symbols": "^1.2.69",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify/svelte": "^5.2.1",
    "@nyx/plugin-api": "workspace:*",
    "@nyx/project-format": "workspace:*",
    "@nyx/shared": "workspace:*",
    "@nyx/ui-kit": "workspace:*",
    "electron-updater": "^6.3.9",
    "esbuild": "^0.21.0",
    "js-yaml": "^4.1.0",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.52.2",
    "pixi.js": "^7.3.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tsconfig/svelte": "^5.0.4",
    "@types/js-yaml": "^4.0.9",
    "electron": "34.3.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "sass": "^1.80.0",
    "svelte": "^5.25.6",
    "svelte-check": "^4.1.5",
    "typescript": "^5.8.3",
    "vite": "^6.2.6"
  }
}
