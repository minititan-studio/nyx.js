{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "include": ["src/**/*", "src/**/*.svelte"],
  "compilerOptions": {
    "composite": true,
    "outDir": "out",
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true
  }
}
